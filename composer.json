{
    "name": "soucul/backend-api",
    "description": "SouCul Backend REST API",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "vlucas/phpdotenv": "^5.6",
        "nikic/fast-route": "^1.3",
        "monolog/monolog": "^3.0",
        "firebase/php-jwt": "^6.10"
    },
    "autoload": {
        "psr-4": {
            "App\\Admin\\": "admin/",
            "App\\Customer\\": "customer/",
            "App\\Shared\\": "shared/"
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}
