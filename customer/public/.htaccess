Options -MultiViews
RewriteEngine On

# Production environment variables (uncomment and set in hosting panel if needed)
# SetEnv DB_HOST localhost
# SetEnv DB_PORT 3306
# SetEnv DB_NAME your_database_name
# SetEnv DB_USER your_database_user
# SetEnv DB_PASS your_database_password
# SetEnv JWT_SECRET replace_with_long_random_secret
# SetEnv JWT_EXPIRY_SECONDS 28800

# Route API requests through customer front controller.
RewriteRule ^api(/.*)?$ index.php [QSA,L]

# Route CORS preflight through PHP handler.
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ index.php [QSA,L]

# Keep direct access to real files/folders.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback all remaining routes to customer front controller.
RewriteRule ^ index.php [QSA,L]
