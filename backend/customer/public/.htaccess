RewriteEngine On
DirectoryIndex index.php

# Hostinger production template (uncomment and replace values)
SetEnv APP_ENV production
SetEnv APP_DEBUG false
SetEnv APP_URL https://api-customer.paleturquoise-gerbil-565865.hostingersite.com
#
SetEnv DB_CONNECTION mysql
SetEnv DB_HOST localhost
SetEnv DB_PORT 3306
SetEnv DB_NAME u990221790_soucul
SetEnv DB_DATABASE u990221790_soucul
SetEnv DB_USER u990221790_soucul_dev
SetEnv DB_USERNAME u990221790_soucul_dev
SetEnv DB_PASS SouCul@Dev2026
SetEnv DB_PASSWORD SouCul@Dev2026
#
SetEnv JWT_SECRET SoulCulSecureJWTSecretKey2026MinimumThirtyTwoCharactersRequired
SetEnv JWT_EXPIRY_SECONDS 86400
SetEnv JWT_EXPIRY 86400
#
SetEnv CORS_ALLOWED_ORIGINS "https://paleturquoise-gerbil-565865.hostingersite.com,https://www.paleturquoise-gerbil-565865.hostingersite.com,https://api-admin.paleturquoise-gerbil-565865.hostingersite.com,https://api-customer.paleturquoise-gerbil-565865.hostingersite.com"

# Route API requests through customer front controller.
RewriteRule ^api(/.*)?$ index.php [QSA,L]

# Route CORS preflight through PHP handler.
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ index.php [QSA,L]

# Keep direct access to real files/folders.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Fallback all remaining routes to customer front controller.
RewriteRule ^ index.php [QSA,L]
