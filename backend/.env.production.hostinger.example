# SoulCul production environment template for Hostinger
#
# Use this as a reference for production values.
# On Hostinger shared hosting, also copy these values into SetEnv lines in:
# - backend/admin/public/.htaccess
# - backend/customer/public/.htaccess

APP_NAME="SoulCul API"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api-admin.paleturquoise-gerbil-565865.hostingersite.com

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306

# Database keys supported by current backend code (both pairs are accepted).
DB_NAME=u990221790_soucul
DB_DATABASE=u990221790_soucul
DB_USER=u990221790_soucul_dev
DB_USERNAME=u990221790_soucul_dev
DB_PASS=SouCul@Dev2026
DB_PASSWORD=SouCul@Dev2026

# Use a long random secret (at least 32 characters; 64+ recommended).
JWT_SECRET=SoulCulSecureJWTSecretKey2026MinimumThirtyTwoCharactersRequired
JWT_EXPIRY_SECONDS=86400

# Optional legacy key for compatibility with older docs/scripts.
JWT_EXPIRY=86400

# Comma-separated frontend origins allowed to call the API.
CORS_ALLOWED_ORIGINS="https://paleturquoise-gerbil-565865.hostingersite.com,https://www.paleturquoise-gerbil-565865.hostingersite.com,https://api-admin.paleturquoise-gerbil-565865.hostingersite.com,https://api-customer.paleturquoise-gerbil-565865.hostingersite.com"
